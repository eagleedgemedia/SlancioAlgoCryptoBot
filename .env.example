# ═══════════════════════════════════════════════════════
# KSL Algo Crypto Bot - Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ── Delta Exchange API ──
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here
# Options: "global" (api.delta.exchange) or "india" (api.india.delta.exchange)
DELTA_EXCHANGE_REGION=india

# ── Trading Configuration ──
TRADING_SYMBOL=BTCUSDT
TRADING_TIMEFRAME=1h
MAX_LEVERAGE=10
MAX_POSITION_PCT=0.02
STOP_LOSS_POINTS=600
EMA_PERIOD=7
MIN_DISTANCE_FROM_EMA_LOW=400

# ── Database ──
DATABASE_URL=postgresql+asyncpg://ksl_bot:your_password@localhost:5432/ksl_crypto_bot
# For development/testing with SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./ksl_crypto_bot.db

# ── Security ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ── Telegram Notifications ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Application ──
APP_ENV=development
LOG_LEVEL=INFO
